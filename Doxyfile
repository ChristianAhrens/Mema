# Doxyfile for Mema
PROJECT_NAME           = "Mema"
PROJECT_BRIEF          = "Memory Matrix — multi-channel audio matrix monitor and router"
PROJECT_LOGO           = Resources/Images/Mema.png
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO

INPUT                  = Source MemaMo MemaRe README.md CHANGELOG.md
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.cpp *.md
EXCLUDE_PATTERNS       = */submodules/* */JuceLibraryCode/* */Builds/*
USE_MDFILE_AS_MAINPAGE = README.md

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
SHOW_INCLUDE_FILES     = YES
SHOW_USED_FILES        = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = NO
GENERATE_BUGLIST       = NO
GENERATE_DEPRECATEDLIST= YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO

HTML_EXTRA_STYLESHEET  = submodules/doxygen-awesome-css/doxygen-awesome.css \
                         submodules/doxygen-awesome-css/doxygen-awesome-sidebar-only.css
HTML_EXTRA_FILES       = submodules/doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js \
                         submodules/doxygen-awesome-css/doxygen-awesome-fragment-copy-button.js \
                         submodules/doxygen-awesome-css/doxygen-awesome-paragraph-link.js \
                         submodules/doxygen-awesome-css/doxygen-awesome-interactive-toc.js
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_SECTIONS  = YES
HTML_INDEX_NUM_ENTRIES = 100

DISABLE_INDEX          = NO
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
TREEVIEW_WIDTH         = 280
ENUM_VALUES_PER_LINE   = 1

MERMAID_PATH           = mmdc

HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_TRANSPARENT        = YES

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = JUCE_DECLARE_NON_COPYABLE_WITH_LEAK_DETECTOR(x)= \
                         JUCE_DECLARE_WEAK_REFERENCEABLE(x)= \
                         JUCE_DECLARE_SINGLETON(x,y)= \
                         JUCE_DECLARE_SINGLETON_SINGLETHREADED(x,y)=

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_LOGFILE           =
